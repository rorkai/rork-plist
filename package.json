{
  "name": "rork-plist",
  "version": "0.3.0",
  "description": "Zero-dependency Apple property list (plist) parser and builder that runs identically in every JavaScript runtime",
  "keywords": [
    "apple",
    "builder",
    "parser",
    "plist",
    "property-list",
    "xml",
    "zero-dependency"
  ],
  "homepage": "https://github.com/rorkai/rork-plist#readme",
  "bugs": {
    "url": "https://github.com/rorkai/rork-plist/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rorkai/rork-plist.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "checks": "pnpm build && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "bench": "pnpm build && vitest bench --run",
    "prepublishOnly": "pnpm checks"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "eslint": "8.57.1",
    "eslint-plugin-perfectionist": "5.9.1",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
