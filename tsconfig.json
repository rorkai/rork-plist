{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "lib": ["ES2022"],
    "types": ["vitest/globals", "node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  // bench/ is excluded on purpose: benchmarks import the built artifact in
  // dist/, so including them would make a fresh-checkout `pnpm typecheck`
  // fail until a build runs. `pnpm bench` builds first and surfaces breakage.
  "include": ["src", "tests", "tsdown.config.ts", "vitest.config.ts"]
}
